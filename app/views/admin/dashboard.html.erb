<%= turbo_frame_tag "admin-dashboard" do %>

<div style="background: #0a0e17; min-height: 100vh; padding: 24px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: #c8d2e1;">

  <div style="max-width: 1200px; margin: 0 auto;">

    <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; margin-bottom: 24px;">
      <div>
        <h1 style="color: #4fc3f7; margin: 0 0 4px; font-size: 28px;">Globe Tracker Admin</h1>
        <p style="color: #6b7a8d; margin: 0; font-size: 14px;">Last refreshed: <%= Time.current.strftime("%H:%M:%S UTC") %></p>
      </div>
      <a href="<%= admin_api_health_path %>" style="padding: 10px 20px; border-radius: 6px; font-size: 13px; font-weight: 600; text-decoration: none; background: #141a28; color: #4fc3f7; border: 1px solid #1e2a3a;">
        API Health Monitor &rarr;
      </a>
    </div>

    <%# ── Poller Status ── %>
    <div style="background: #141a28; border-radius: 8px; padding: 20px; margin-bottom: 20px; border: 1px solid #1e2a3a;">
      <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;">
        <div>
          <h2 style="margin: 0 0 8px; font-size: 18px; color: #e0e6ed;">Dedicated Poller</h2>
          <div style="display: flex; gap: 24px; flex-wrap: wrap;">
            <span>
              Status:
              <% if @poller_status[:paused] %>
                <span style="color: #ffa726; font-weight: 600;">Paused</span>
              <% elsif @poller_status[:running] %>
                <span style="color: #66bb6a; font-weight: 600;">Running</span>
              <% elsif @poller_status[:stopped] %>
                <span style="color: #ef5350; font-weight: 600;">Disabled</span>
              <% elsif @poller_status[:stale] %>
                <span style="color: #ffb300; font-weight: 600;">No Recent Tick</span>
              <% else %>
                <span style="color: #ef5350; font-weight: 600;">Stopped</span>
              <% end %>
            </span>
            <% if @poller_status[:started_at] %>
              <span>Started: <strong><%= @poller_status[:started_at]&.strftime("%H:%M:%S") %></strong></span>
            <% end %>
            <% if @poller_status[:last_poll_at] %>
              <span>Last tick: <strong><%= @poller_status[:last_poll_at]&.strftime("%H:%M:%S") %></strong></span>
            <% end %>
            <% if @poller_status[:last_heartbeat_at] %>
              <span>Last heartbeat: <strong><%= @poller_status[:last_heartbeat_at]&.strftime("%H:%M:%S") %></strong></span>
            <% end %>
            <span>Polls: <strong><%= @poller_status[:poll_count] %></strong></span>
            <span>Desired: <strong><%= @poller_status[:desired_state] %></strong></span>
            <span>AIS: <strong><%= @poller_status[:ais_mode] %></strong></span>
          </div>
          <div style="margin-top: 8px; color: #6b7a8d; font-size: 12px;">
            Managed by the poller runtime (<code><%= @poller_status[:scheduler] %></code>). Sidekiq executes the enqueued jobs. Live layers run at independent cadences, and AIS streaming is owned by the poller runtime when the API key is present.
          </div>
        </div>
        <div style="display: flex; gap: 8px;">
          <% if @poller_status[:running] || @poller_status[:paused] %>
            <%= form_tag admin_pause_poller_path, method: :post, style: "margin: 0;" do %>
              <button type="submit" style="background: <%= @poller_status[:paused] ? '#ffa726' : '#42a5f5' %>; color: #fff; border: none; padding: 10px 24px; border-radius: 6px; cursor: pointer; font-size: 14px; font-weight: 600;">
                <%= @poller_status[:paused] ? "Resume" : "Pause" %>
              </button>
            <% end %>
            <%= form_tag admin_stop_poller_path, method: :post, style: "margin: 0;" do %>
              <button type="submit" style="background: #ef5350; color: #fff; border: none; padding: 10px 24px; border-radius: 6px; cursor: pointer; font-size: 14px; font-weight: 600;">
                Disable
              </button>
            <% end %>
          <% else %>
            <%= form_tag admin_toggle_poller_path, method: :post, style: "margin: 0;" do %>
              <button type="submit" style="background: #66bb6a; color: #fff; border: none; padding: 10px 24px; border-radius: 6px; cursor: pointer; font-size: 14px; font-weight: 600;">
                Enable
              </button>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <%# ── Snapshot Counts ── %>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 20px;">
      <div style="background: #141a28; border-radius: 8px; padding: 16px; border: 1px solid #1e2a3a; text-align: center;">
        <div style="font-size: 28px; font-weight: 700; color: #4fc3f7;"><%= number_with_delimiter(@snapshot_counts[:total]) %></div>
        <div style="color: #6b7a8d; font-size: 13px; margin-top: 4px;">Total Snapshots</div>
      </div>
      <div style="background: #141a28; border-radius: 8px; padding: 16px; border: 1px solid #1e2a3a; text-align: center;">
        <div style="font-size: 28px; font-weight: 700; color: #4fc3f7;"><%= number_with_delimiter(@snapshot_counts[:last_hour]) %></div>
        <div style="color: #6b7a8d; font-size: 13px; margin-top: 4px;">Last Hour</div>
      </div>
      <div style="background: #141a28; border-radius: 8px; padding: 16px; border: 1px solid #1e2a3a; text-align: center;">
        <div style="font-size: 28px; font-weight: 700; color: #4fc3f7;"><%= number_with_delimiter(@snapshot_counts[:flights_hour]) %></div>
        <div style="color: #6b7a8d; font-size: 13px; margin-top: 4px;">Flight Snapshots (1h)</div>
      </div>
      <div style="background: #141a28; border-radius: 8px; padding: 16px; border: 1px solid #1e2a3a; text-align: center;">
        <div style="font-size: 28px; font-weight: 700; color: #4fc3f7;"><%= number_with_delimiter(@snapshot_counts[:ships_hour]) %></div>
        <div style="color: #6b7a8d; font-size: 13px; margin-top: 4px;">Ship Snapshots (1h)</div>
      </div>
    </div>

    <%# ── Stats Summary ── %>
    <div style="background: #141a28; border-radius: 8px; padding: 20px; margin-bottom: 20px; border: 1px solid #1e2a3a;">
      <h2 style="margin: 0 0 12px; font-size: 18px; color: #e0e6ed;">Polling Summary (Last Hour)</h2>
      <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; font-size: 14px;">
          <thead>
            <tr style="border-bottom: 2px solid #1e2a3a;">
              <th style="text-align: left; padding: 8px 12px; color: #6b7a8d; font-weight: 600;">Source</th>
              <th style="text-align: left; padding: 8px 12px; color: #6b7a8d; font-weight: 600;">Type</th>
              <th style="text-align: right; padding: 8px 12px; color: #6b7a8d; font-weight: 600;">Polls</th>
              <th style="text-align: right; padding: 8px 12px; color: #6b7a8d; font-weight: 600;">Fetched</th>
              <th style="text-align: right; padding: 8px 12px; color: #6b7a8d; font-weight: 600;">Stored</th>
              <th style="text-align: right; padding: 8px 12px; color: #6b7a8d; font-weight: 600;">Avg Duration</th>
              <th style="text-align: right; padding: 8px 12px; color: #6b7a8d; font-weight: 600;">Errors</th>
              <th style="text-align: right; padding: 8px 12px; color: #6b7a8d; font-weight: 600;">Last Poll</th>
            </tr>
          </thead>
          <tbody>
            <% @stats_summary.each do |stat| %>
              <tr style="border-bottom: 1px solid #1e2a3a;">
                <td style="padding: 8px 12px; font-weight: 600;"><%= stat.source %></td>
                <td style="padding: 8px 12px;"><%= stat.poll_type %></td>
                <td style="padding: 8px 12px; text-align: right;"><%= stat.poll_count %></td>
                <td style="padding: 8px 12px; text-align: right;"><%= number_with_delimiter(stat.total_fetched.to_i) %></td>
                <td style="padding: 8px 12px; text-align: right;"><%= number_with_delimiter(stat.total_stored.to_i) %></td>
                <td style="padding: 8px 12px; text-align: right;"><%= stat.avg_duration.to_i %> ms</td>
                <td style="padding: 8px 12px; text-align: right; color: <%= stat.error_count.to_i > 0 ? '#ef5350' : '#66bb6a' %>;"><%= stat.error_count %></td>
                <td style="padding: 8px 12px; text-align: right;"><%= stat.last_poll_at&.strftime("%H:%M:%S") %></td>
              </tr>
            <% end %>
            <% if @stats_summary.empty? %>
              <tr><td colspan="8" style="padding: 16px; text-align: center; color: #6b7a8d;">No polling data yet</td></tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <%# ── Feed Health ── %>
    <div style="background: #141a28; border-radius: 8px; padding: 20px; margin-bottom: 20px; border: 1px solid #1e2a3a;">
      <h2 style="margin: 0 0 12px; font-size: 18px; color: #e0e6ed;">Feed Health</h2>
      <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
          <thead>
            <tr style="border-bottom: 2px solid #1e2a3a;">
              <th style="text-align: left; padding: 6px 10px; color: #6b7a8d; font-weight: 600;">Feed</th>
              <th style="text-align: left; padding: 6px 10px; color: #6b7a8d; font-weight: 600;">Provider</th>
              <th style="text-align: center; padding: 6px 10px; color: #6b7a8d; font-weight: 600;">Status</th>
              <th style="text-align: right; padding: 6px 10px; color: #6b7a8d; font-weight: 600;">Fetched</th>
              <th style="text-align: right; padding: 6px 10px; color: #6b7a8d; font-weight: 600;">Stored</th>
              <th style="text-align: right; padding: 6px 10px; color: #6b7a8d; font-weight: 600;">HTTP</th>
              <th style="text-align: right; padding: 6px 10px; color: #6b7a8d; font-weight: 600;">Last Success</th>
              <th style="text-align: left; padding: 6px 10px; color: #6b7a8d; font-weight: 600;">Last Error</th>
            </tr>
          </thead>
          <tbody>
            <% @feed_statuses.each do |feed| %>
              <% badge_bg, badge_color = case feed.status
                 when "success" then ["#1b3a2a", "#66bb6a"]
                 when "disabled" then ["#2a2538", "#b39ddb"]
                 when "error" then ["#3a1b1b", "#ef5350"]
                 else ["#233044", "#90a4ae"]
                 end %>
              <tr style="border-bottom: 1px solid #1e2a3a;">
                <td style="padding: 6px 10px; font-weight: 600;"><%= feed.display_name %></td>
                <td style="padding: 6px 10px;"><%= feed.provider %> / <%= feed.feed_kind %></td>
                <td style="padding: 6px 10px; text-align: center;">
                  <span style="display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; background: <%= badge_bg %>; color: <%= badge_color %>;">
                    <%= feed.status %>
                  </span>
                </td>
                <td style="padding: 6px 10px; text-align: right;"><%= number_with_delimiter(feed.last_records_fetched) %></td>
                <td style="padding: 6px 10px; text-align: right;"><%= number_with_delimiter(feed.last_records_stored) %></td>
                <td style="padding: 6px 10px; text-align: right;"><%= feed.last_http_status || "—" %></td>
                <td style="padding: 6px 10px; text-align: right;"><%= feed.last_success_at&.strftime("%m-%d %H:%M") || "—" %></td>
                <td style="padding: 6px 10px; color: #ef5350; max-width: 260px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="<%= feed.last_error_message %>">
                  <%= feed.last_error_at ? "#{feed.last_error_at.strftime('%m-%d %H:%M')} · #{feed.last_error_message}" : "—" %>
                </td>
              </tr>
            <% end %>
            <% if @feed_statuses.empty? %>
              <tr><td colspan="8" style="padding: 16px; text-align: center; color: #6b7a8d;">No per-feed status yet</td></tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <%# ── Data Freshness ── %>
    <div style="background: #141a28; border-radius: 8px; padding: 20px; margin-bottom: 20px; border: 1px solid #1e2a3a;">
      <h2 style="margin: 0 0 12px; font-size: 18px; color: #e0e6ed;">Data Freshness</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px;">
        <% @freshness.each do |layer, timestamp| %>
          <div style="background: #0d1320; border-radius: 6px; padding: 12px;">
            <div style="color: #6b7a8d; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px;"><%= layer %></div>
            <% if timestamp %>
              <% age_minutes = ((Time.current - timestamp) / 60).round %>
              <div style="font-size: 16px; font-weight: 600; color: <%= age_minutes > 30 ? '#ef5350' : age_minutes > 10 ? '#ffa726' : '#66bb6a' %>;">
                <%= time_ago_in_words(timestamp) %> ago
              </div>
              <div style="color: #4a5568; font-size: 11px;"><%= timestamp.strftime("%H:%M:%S") %></div>
            <% else %>
              <div style="font-size: 16px; color: #4a5568;">No data</div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Recent Poll Log ── %>
    <div style="background: #141a28; border-radius: 8px; padding: 20px; border: 1px solid #1e2a3a;">
      <h2 style="margin: 0 0 12px; font-size: 18px; color: #e0e6ed;">Recent Poll Log</h2>
      <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
          <thead>
            <tr style="border-bottom: 2px solid #1e2a3a;">
              <th style="text-align: left; padding: 6px 10px; color: #6b7a8d; font-weight: 600;">Time</th>
              <th style="text-align: left; padding: 6px 10px; color: #6b7a8d; font-weight: 600;">Source</th>
              <th style="text-align: left; padding: 6px 10px; color: #6b7a8d; font-weight: 600;">Type</th>
              <th style="text-align: right; padding: 6px 10px; color: #6b7a8d; font-weight: 600;">Fetched</th>
              <th style="text-align: right; padding: 6px 10px; color: #6b7a8d; font-weight: 600;">Stored</th>
              <th style="text-align: right; padding: 6px 10px; color: #6b7a8d; font-weight: 600;">Duration</th>
              <th style="text-align: center; padding: 6px 10px; color: #6b7a8d; font-weight: 600;">Status</th>
              <th style="text-align: left; padding: 6px 10px; color: #6b7a8d; font-weight: 600;">Error</th>
            </tr>
          </thead>
          <tbody>
            <% @recent_stats.limit(50).each do |stat| %>
              <tr style="border-bottom: 1px solid #1e2a3a;">
                <td style="padding: 6px 10px; color: #8892a4;"><%= stat.created_at.strftime("%H:%M:%S") %></td>
                <td style="padding: 6px 10px; font-weight: 600;"><%= stat.source %></td>
                <td style="padding: 6px 10px;"><%= stat.poll_type %></td>
                <td style="padding: 6px 10px; text-align: right;"><%= number_with_delimiter(stat.records_fetched) %></td>
                <td style="padding: 6px 10px; text-align: right;"><%= number_with_delimiter(stat.records_stored) %></td>
                <td style="padding: 6px 10px; text-align: right;"><%= stat.duration_ms %> ms</td>
                <td style="padding: 6px 10px; text-align: center;">
                  <span style="display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; background: <%= stat.status == 'success' ? '#1b3a2a' : '#3a1b1b' %>; color: <%= stat.status == 'success' ? '#66bb6a' : '#ef5350' %>;">
                    <%= stat.status %>
                  </span>
                </td>
                <td style="padding: 6px 10px; color: #ef5350; font-size: 12px; max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="<%= stat.error_message %>">
                  <%= stat.error_message %>
                </td>
              </tr>
            <% end %>
            <% if @recent_stats.empty? %>
              <tr><td colspan="8" style="padding: 16px; text-align: center; color: #6b7a8d;">No recent polls</td></tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>
<% end %>

<script>
  // Auto-refresh the turbo frame every 10 seconds
  setInterval(() => {
    const frame = document.querySelector("turbo-frame#admin-dashboard")
    if (frame) frame.reload()
  }, 10000)
</script>

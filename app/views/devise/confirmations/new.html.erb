<div class="auth-shell">
  <div class="auth-layout">
    <section class="auth-panel">
      <p class="auth-eyebrow">Email Confirmation</p>
      <h1 class="auth-title">Confirm the account before it becomes an active workspace identity.</h1>
      <p class="auth-copy">If the original confirmation email is gone or expired, request another one here.</p>
    </section>

    <section class="auth-card">
      <p class="auth-card-kicker">Confirmation</p>
      <h2 class="auth-card-title">Resend confirmation email</h2>
      <p class="auth-card-copy">We’ll send a fresh confirmation link to the address attached to this account.</p>

      <%= render "devise/shared/error_messages", resource: resource %>

      <%= simple_form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post, class: "auth-form" }) do |f| %>
        <%= f.full_error :confirmation_token %>
        <%= f.input :email,
                    required: true,
                    autofocus: true,
                    label: "Email",
                    value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email),
                    input_html: { class: "auth-field", autocomplete: "email", placeholder: "operator@globetracker" } %>

        <div class="auth-actions">
          <%= f.button :submit, "Resend confirmation", class: "auth-submit" %>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </section>
  </div>
</div>

<%= render "devise/shared/auth_shell",
           eyebrow: "Email Verification",
           title: "Resend confirmation",
           subtitle: "Issue a fresh verification email so the operator account can complete sign-in and recovery flows.",
           signal: {
             label: "Verification",
             value: "MAIL",
             detail: "Confirmation keeps the account reachable for recovery links and security notifications."
           } do %>
  <%= simple_form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post, class: "auth-form" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <% if resource.errors[:confirmation_token].present? %>
      <div class="auth-token-error"><%= resource.errors.full_messages_for(:confirmation_token).to_sentence %></div>
    <% end %>

    <div class="auth-form-grid">
      <%= f.input :email,
                  required: true,
                  autofocus: true,
                  value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email),
                  input_html: { autocomplete: "email" } %>
    </div>

    <div class="auth-form-actions">
      <%= f.button :submit, "Resend confirmation", class: "auth-submit" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>

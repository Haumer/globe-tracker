<%= render "devise/shared/auth_shell",
           eyebrow: "Reset password",
           title: "Forgot your password?",
           subtitle: "Enter your email and we'll send a reset link." do %>
  <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "auth-form" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="auth-form-grid">
      <%= f.input :email,
                  required: true,
                  autofocus: true,
                  label: "Email",
                  input_html: { autocomplete: "email", placeholder: "you@example.com" } %>
    </div>

    <div class="auth-form-actions">
      <%= f.button :submit, "Send reset link", class: "auth-submit" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>

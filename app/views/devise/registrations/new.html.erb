<%= render "devise/shared/auth_shell",
           eyebrow: "Create account",
           title: "Get started" do %>
  <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="auth-form-grid">
      <%= f.input :email,
                  required: true,
                  autofocus: true,
                  label: "Email",
                  input_html: { autocomplete: "email", placeholder: "you@example.com" } %>
      <%= f.input :password,
                  required: true,
                  label: "Password",
                  hint: ("#{@minimum_password_length} characters minimum" if @minimum_password_length),
                  input_html: { autocomplete: "new-password" } %>
      <%= f.input :password_confirmation,
                  required: true,
                  label: "Confirm password",
                  input_html: { autocomplete: "new-password" } %>
    </div>

    <div class="auth-form-actions">
      <%= f.button :submit, "Create account", class: "auth-submit" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>

<%= render "devise/shared/auth_shell",
           eyebrow: "Sign in",
           title: "Welcome back" do %>
  <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="auth-form-grid">
      <%= f.input :email,
                  required: false,
                  autofocus: true,
                  label: "Email",
                  input_html: { autocomplete: "email", placeholder: "you@example.com" } %>
      <%= f.input :password,
                  required: false,
                  label: "Password",
                  input_html: { autocomplete: "current-password" } %>
    </div>

    <% if devise_mapping.rememberable? %>
      <label class="auth-remember">
        <%= f.input_field :remember_me, as: :boolean %>
        <span>Remember me</span>
      </label>
    <% end %>

    <div class="auth-form-actions">
      <%= f.button :submit, "Sign in", class: "auth-submit" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>

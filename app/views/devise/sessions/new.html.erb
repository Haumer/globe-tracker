<%= render "devise/shared/auth_shell",
           eyebrow: "Secure Access",
           title: "Resume your watchfloor",
           subtitle: "Sign in to return to saved alerts, active watches, and case work without losing globe context.",
           signal: {
             label: "Session posture",
             value: "AUTH",
             detail: "A signed-in session unlocks case creation, pinned evidence, and analyst-specific alerts."
           } do %>
  <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="auth-form-grid">
      <%= f.input :email,
                  required: false,
                  autofocus: true,
                  input_html: { autocomplete: "email" } %>
      <%= f.input :password,
                  required: false,
                  input_html: { autocomplete: "current-password" } %>
      <%= f.input :remember_me, as: :boolean if devise_mapping.rememberable? %>
    </div>

    <div class="auth-form-actions">
      <%= f.button :submit, "Log in", class: "auth-submit" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>

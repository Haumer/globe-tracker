<div class="auth-links">
  <div class="auth-links__label">Need another route?</div>

  <div class="auth-link-row">
    <%- if controller_name != "sessions" %>
      <%= link_to "Log in", new_session_path(resource_name), class: "auth-link" %>
    <% end %>

    <%- if devise_mapping.registerable? && controller_name != "registrations" %>
      <%= link_to "Create account", new_registration_path(resource_name), class: "auth-link" %>
    <% end %>

    <%- if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
      <%= link_to "Reset password", new_password_path(resource_name), class: "auth-link" %>
    <% end %>

    <%- if devise_mapping.confirmable? && controller_name != "confirmations" %>
      <%= link_to "Resend confirmation", new_confirmation_path(resource_name), class: "auth-link" %>
    <% end %>

    <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != "unlocks" %>
      <%= link_to "Resend unlock email", new_unlock_path(resource_name), class: "auth-link" %>
    <% end %>
  </div>

  <%- if devise_mapping.omniauthable? %>
    <%- resource_class.omniauth_providers.each do |provider| %>
      <%= button_to "Sign in with #{OmniAuth::Utils.camelize(provider)}",
                    omniauth_authorize_path(resource_name, provider),
                    data: { turbo: false },
                    class: "auth-provider-btn",
                    form_class: "auth-provider-form" %>
    <% end %>
  <% end %>
</div>

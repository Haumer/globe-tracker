<%= render "devise/shared/auth_shell",
           eyebrow: "Account Recovery",
           title: "Unlock operator access",
           subtitle: "Request a fresh unlock email when repeated login attempts have tripped the account lock.",
           signal: {
             label: "Lock status",
             value: "SAFE",
             detail: "Unlock flows restore access without changing account ownership, watches, or case history."
           } do %>
  <%= simple_form_for(resource, as: resource_name, url: unlock_path(resource_name), html: { method: :post, class: "auth-form" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <% if resource.errors[:unlock_token].present? %>
      <div class="auth-token-error"><%= resource.errors.full_messages_for(:unlock_token).to_sentence %></div>
    <% end %>

    <div class="auth-form-grid">
      <%= f.input :email,
                  required: true,
                  autofocus: true,
                  input_html: { autocomplete: "email" } %>
    </div>

    <div class="auth-form-actions">
      <%= f.button :submit, "Send unlock instructions", class: "auth-submit" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>

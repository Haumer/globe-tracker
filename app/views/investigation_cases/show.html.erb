<% workspace = @case_workspace %>
<% primary_object = workspace&.dig(:primary_object) %>
<% source_context = workspace&.dig(:source_context) || {} %>
<% brief_state = investigation_case_theater_brief_state(workspace) %>

<div class="case-shell">
  <section class="case-hero case-hero--detail">
    <div class="case-hero-main">
      <div class="case-kicker">
        <span><%= @investigation_case.case_code %></span>
        <span class="case-kicker-sep"></span>
        <span><%= pluralize(@case_objects.size, "pinned object") %></span>
      </div>
      <h1 class="case-title"><%= @investigation_case.title %></h1>
      <% if @investigation_case.summary.present? %>
        <p class="case-summary"><%= @investigation_case.summary %></p>
      <% end %>

      <div class="case-badges case-badges--hero">
        <span class="case-badge <%= investigation_case_status_class(@investigation_case.status) %>"><%= investigation_case_status_label(@investigation_case.status) %></span>
        <span class="case-badge <%= investigation_case_severity_class(@investigation_case.severity) %>"><%= investigation_case_severity_label(@investigation_case.severity) %></span>
        <% if primary_object.present? %>
          <span class="case-object-pill">Primary Focus</span>
          <span class="case-object-pill case-object-pill--muted"><%= investigation_case_primary_object_kind_label(primary_object) %></span>
          <% if (source_label = investigation_case_source_context_label(source_context)).present? %>
            <span class="case-badge case-badge--highlight"><%= source_label %></span>
          <% end %>
        <% end %>
      </div>

      <div class="case-meta-grid">
        <% if primary_object.present? %>
          <div class="case-meta-card">
            <span class="case-meta-label">Primary Focus</span>
            <span class="case-meta-value"><%= primary_object.title %></span>
          </div>
        <% end %>
        <% if source_context[:pulse_score].present? %>
          <div class="case-meta-card">
            <span class="case-meta-label">Pulse</span>
            <span class="case-meta-value"><%= source_context[:pulse_score] %></span>
          </div>
        <% end %>
        <div class="case-meta-card">
          <span class="case-meta-label">Owner</span>
          <span class="case-meta-value"><%= @investigation_case.user.email %></span>
        </div>
        <div class="case-meta-card">
          <span class="case-meta-label">Assignee</span>
          <span class="case-meta-value"><%= @investigation_case.assignee_email %></span>
        </div>
        <div class="case-meta-card">
          <span class="case-meta-label">Last Updated</span>
          <span class="case-meta-value"><%= @investigation_case.updated_at.strftime("%Y-%m-%d %H:%M UTC") %></span>
        </div>
        <% if brief_state.present? %>
          <div class="case-meta-card">
            <span class="case-meta-label">Brief State</span>
            <span class="case-meta-value"><%= brief_state %></span>
          </div>
        <% end %>
      </div>

      <div class="case-actions">
        <%= link_to "All Cases", cases_path, class: "case-action" %>
        <%= link_to "Return To Globe", investigation_case_return_globe_href(@return_to_globe), class: "case-action case-action--primary" %>
      </div>
    </div>

    <aside class="case-hero-side">
      <div class="case-side-block">
        <div class="case-side-label">Pinned Objects</div>
        <div class="case-side-stat"><%= @case_objects.size %></div>
        <div class="case-side-meta">durable linked nodes</div>
      </div>
      <div class="case-side-block">
        <div class="case-side-label">Notes</div>
        <div class="case-side-stat"><%= @case_notes.size %></div>
        <div class="case-side-meta">analyst updates and observations</div>
      </div>
      <% if workspace.present? %>
        <div class="case-side-block">
          <div class="case-side-label">Linked Nodes</div>
          <div class="case-side-stat"><%= Array(workspace.dig(:node_context, :relationships)).size %></div>
          <div class="case-side-meta">durable graph relationships</div>
        </div>
      <% end %>
    </aside>
  </section>

  <% if workspace.present? %>
    <div class="case-workspace-grid">
      <section class="case-card case-card--workspace-main">
        <div class="case-card-head">
          <h2>Operational Assessment</h2>
          <span><%= primary_object.title %></span>
        </div>

        <div class="case-workspace-copy"><%= workspace[:assessment] %></div>

        <% if workspace[:why_we_believe_it].any? %>
          <div class="case-workspace-block">
            <div class="case-section-label">Why This Read</div>
            <ul class="case-bullet-list">
              <% workspace[:why_we_believe_it].each do |item| %>
                <li><%= item %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <% if workspace[:watch_next].any? %>
          <div class="case-workspace-block">
            <div class="case-section-label">Watch Next</div>
            <ul class="case-bullet-list">
              <% workspace[:watch_next].each do |item| %>
                <li><%= item %></li>
              <% end %>
            </ul>
          </div>
        <% end %>
      </section>

      <div class="case-workspace-side">
        <section class="case-card case-card--workspace-focus">
          <div class="case-card-head">
            <h2>Primary Focus</h2>
            <span><%= investigation_case_primary_object_kind_label(primary_object) %></span>
          </div>

          <% if primary_object.summary.present? %>
            <p class="case-copy case-copy--workspace"><%= primary_object.summary %></p>
          <% end %>

          <% if workspace[:metrics].any? %>
            <div class="case-workspace-metrics">
              <% workspace[:metrics].each do |metric| %>
                <div class="case-workspace-metric">
                  <span class="case-section-label"><%= metric[:label] %></span>
                  <span class="case-workspace-metric-value"><%= metric[:value] %></span>
                </div>
              <% end %>
            </div>
          <% end %>

          <% if brief_state.present? %>
            <div class="case-workspace-state"><%= brief_state %></div>
          <% end %>

          <div class="case-inline-actions">
            <%= link_to "Open On Globe", investigation_case_object_globe_href(primary_object), class: "case-inline-action case-inline-action--primary" %>
            <% if (object_view_href = investigation_case_primary_object_view_href(primary_object)).present? %>
              <%= link_to "Object View", object_view_href, class: "case-inline-action" %>
            <% end %>
          </div>
        </section>

        <% if (resource_profile = workspace[:resource_profile]).present? %>
          <section class="case-card case-card--workspace-focus">
            <div class="case-card-head">
              <h2><%= resource_profile[:title] %></h2>
              <span><%= resource_profile[:subtitle] %></span>
            </div>

            <% if resource_profile[:summary].present? %>
              <p class="case-copy case-copy--workspace"><%= resource_profile[:summary] %></p>
            <% end %>

            <% if resource_profile[:metrics].present? %>
              <div class="case-workspace-metrics">
                <% resource_profile[:metrics].each do |metric| %>
                  <div class="case-workspace-metric">
                    <span class="case-section-label"><%= metric[:label] %></span>
                    <span class="case-workspace-metric-value"><%= metric[:value] %></span>
                  </div>
                <% end %>
              </div>
            <% end %>
          </section>
        <% end %>

        <section class="case-card case-card--timeline">
          <div class="case-card-head">
            <h2>Case Timeline</h2>
            <span><%= workspace[:timeline_entries].size %></span>
          </div>

          <div class="case-timeline">
            <% workspace[:timeline_entries].each do |entry| %>
              <article class="case-timeline-item">
                <div class="case-timeline-top">
                  <span class="case-badge <%= investigation_case_timeline_badge_class(entry[:kind]) %>"><%= entry[:kind].to_s.titleize %></span>
                  <span class="case-note-time"><%= entry[:at].strftime("%Y-%m-%d %H:%M UTC") %></span>
                </div>
                <div class="case-timeline-title"><%= entry[:title] %></div>
                <% if entry[:meta].present? %>
                  <div class="case-timeline-meta"><%= entry[:meta] %></div>
                <% end %>
              </article>
            <% end %>
          </div>
        </section>
      </div>

      <section class="case-card case-card--workspace-support">
        <div class="case-card-head">
          <h2>Latest Developments</h2>
          <span><%= workspace[:key_developments].size %></span>
        </div>

        <% if workspace[:key_developments].any? %>
          <ul class="case-bullet-list case-bullet-list--developments">
            <% workspace[:key_developments].each do |item| %>
              <li><%= item %></li>
            <% end %>
          </ul>
        <% else %>
          <div class="case-empty case-empty--inline">No current developments are attached to this primary focus yet.</div>
        <% end %>
      </section>

      <% if (supporting_signals = workspace[:supporting_signals]).present? %>
        <section class="case-card case-card--workspace-support">
          <div class="case-card-head">
            <h2>Supporting Signals</h2>
            <span><%= supporting_signals[:scope_label] %></span>
          </div>

          <% supporting_signals[:groups].each do |group| %>
            <div class="case-signal-group">
              <div class="case-section-label"><%= group[:title] %></div>

              <% if group[:note].present? %>
                <p class="case-copy case-copy--workspace case-copy--signal-note"><%= group[:note] %></p>
              <% end %>

              <div class="case-signal-metrics">
                <% group[:metrics].each do |metric| %>
                  <div class="case-workspace-metric">
                    <span class="case-section-label"><%= metric[:label] %></span>
                    <span class="case-workspace-metric-value">
                      <% if metric[:kind] == :time %>
                        <%= metric[:value].present? ? "#{time_ago_in_words(metric[:value])} ago" : "None" %>
                      <% else %>
                        <%= metric[:value] %>
                      <% end %>
                    </span>
                  </div>
                <% end %>
              </div>

              <% if group[:items].any? %>
                <div class="case-signal-list">
                  <% group[:items].each do |item| %>
                    <article class="case-signal-item">
                      <div class="case-signal-top">
                        <span class="case-badge <%= investigation_case_signal_badge_class(item[:kind]) %>"><%= item[:kind_label] %></span>
                        <% if item[:at].present? %>
                          <span class="case-note-time"><%= time_ago_in_words(item[:at]) %> ago</span>
                        <% end %>
                      </div>
                      <div class="case-signal-title"><%= item[:title] %></div>
                      <% if item[:meta].present? %>
                        <div class="case-signal-meta"><%= item[:meta] %></div>
                      <% end %>
                      <% if item[:detail].present? %>
                        <p class="case-copy case-copy--signal"><%= item[:detail] %></p>
                      <% end %>
                    </article>
                  <% end %>
                </div>
              <% else %>
                <div class="case-empty case-empty--inline">No nearby supporting signals are in the current <%= supporting_signals[:scope_label] %>.</div>
              <% end %>
            </div>
          <% end %>
        </section>
      <% end %>

      <section class="case-card case-card--workspace-support">
        <div class="case-card-head">
          <h2>Durable Graph</h2>
          <span><%= workspace[:graph_groups].sum { |group| group[:items].size } %></span>
        </div>

        <% if workspace[:graph_groups].any? %>
          <div class="case-graph-grid">
            <% workspace[:graph_groups].each do |group| %>
              <section class="case-graph-group">
                <div class="case-section-label"><%= group[:title] %></div>
                <div class="case-graph-list">
                  <% group[:items].each do |item| %>
                    <% if (graph_href = investigation_case_graph_item_href(item)).present? %>
                      <%= link_to graph_href, class: "case-graph-item case-graph-item--link" do %>
                        <div class="case-graph-item-label"><%= item[:label] %></div>
                        <% if item[:meta].present? %>
                          <div class="case-graph-item-meta"><%= item[:meta] %></div>
                        <% end %>
                      <% end %>
                    <% else %>
                      <article class="case-graph-item">
                        <div class="case-graph-item-label"><%= item[:label] %></div>
                        <% if item[:meta].present? %>
                          <div class="case-graph-item-meta"><%= item[:meta] %></div>
                        <% end %>
                      </article>
                    <% end %>
                  <% end %>
                </div>
              </section>
            <% end %>
          </div>
        <% else %>
          <div class="case-empty case-empty--inline">Durable graph context has not been resolved for this focus yet.</div>
        <% end %>
      </section>
    </div>
  <% end %>

  <div class="case-grid case-grid--support">
    <section class="case-card">
      <div class="case-card-head">
        <h2>Workflow</h2>
      </div>
      <%= form_with model: @investigation_case, url: case_path(@investigation_case), method: :patch, class: "case-note-form" do |form| %>
        <div class="case-form-grid">
          <div class="case-intake-field">
            <%= form.label :status, "Status" %>
            <%= form.select :status, options_for_select(investigation_case_status_options, @investigation_case.status) %>
          </div>
          <div class="case-intake-field">
            <%= form.label :severity, "Severity" %>
            <%= form.select :severity, options_for_select(investigation_case_severity_options, @investigation_case.severity) %>
          </div>
          <div class="case-intake-field">
            <%= form.label :assignee_id, "Assignee" %>
            <%= form.select :assignee_id, investigation_case_assignable_user_options(@assignable_users, @investigation_case.assignee_id) %>
          </div>
        </div>
        <div class="case-intake-field">
          <%= form.label :summary, "Working summary" %>
          <%= form.text_area :summary, rows: 4 %>
        </div>
        <%= hidden_field_tag :return_to, @return_to_globe if @return_to_globe.present? %>
        <div class="case-note-actions">
          <%= form.submit "Update Case", class: "case-action case-action--primary" %>
        </div>
      <% end %>
    </section>

    <section class="case-card">
      <div class="case-card-head">
        <h2>Pinned Objects</h2>
        <span><%= @case_objects.size %></span>
      </div>
      <% if @case_objects.any? %>
        <div class="case-object-list">
          <% @case_objects.each do |case_object| %>
            <article class="case-object-item">
              <div class="case-object-top">
                <span class="case-object-pill"><%= case_object.object_kind.to_s.tr("_", " ").titleize %></span>
                <% if case_object.object_type.present? %>
                  <span class="case-object-pill case-object-pill--muted"><%= case_object.object_type.to_s.tr("_", " ").titleize %></span>
                <% end %>
              </div>
              <h3><%= case_object.title %></h3>
              <% if case_object.summary.present? %>
                <p class="case-copy"><%= case_object.summary %></p>
              <% end %>
              <div class="case-object-metrics">
                <% if case_object.relationship_count.positive? %>
                  <span><%= pluralize(case_object.relationship_count, "relationship") %></span>
                <% end %>
                <% if case_object.evidence_count.positive? %>
                  <span><%= pluralize(case_object.evidence_count, "evidence item") %></span>
                <% end %>
                <% if case_object.membership_count.positive? %>
                  <span><%= pluralize(case_object.membership_count, "membership") %></span>
                <% end %>
              </div>
              <div class="case-inline-actions">
                <% if investigation_case_object_viewable?(case_object) %>
                  <%= link_to "Object View", investigation_case_object_view_href(case_object), class: "case-inline-action" %>
                <% end %>
                <%= link_to "Open On Globe", investigation_case_object_globe_href(case_object), class: "case-inline-action case-inline-action--primary" %>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="case-empty case-empty--inline">No objects pinned yet.</div>
      <% end %>
    </section>

    <section class="case-card">
      <div class="case-card-head">
        <h2>Notes</h2>
        <span><%= @case_notes.size %></span>
      </div>

      <%= form_with model: @case_note, url: case_notes_path(@investigation_case), class: "case-note-form" do |form| %>
        <div class="case-intake-field">
          <%= form.label :kind, "Note type" %>
          <%= form.select :kind, options_for_select(investigation_case_note_kind_options, "note") %>
        </div>
        <%= hidden_field_tag :return_to, @return_to_globe if @return_to_globe.present? %>
        <%= form.text_area :body, rows: 5, placeholder: "Capture analyst context, next steps, or what changed in this situation." %>
        <div class="case-note-actions">
          <%= form.submit "Add Note", class: "case-action case-action--primary" %>
        </div>
      <% end %>

      <% if @case_notes.any? %>
        <div class="case-note-list">
          <% @case_notes.each do |case_note| %>
            <article class="case-note-item">
              <div class="case-note-top">
                <span class="case-note-author"><%= case_note.user.email %></span>
                <span class="case-badge <%= investigation_case_note_kind_class(case_note.kind) %>"><%= case_note.kind.titleize %></span>
                <span class="case-note-time"><%= case_note.created_at.strftime("%Y-%m-%d %H:%M UTC") %></span>
              </div>
              <p><%= simple_format(case_note.body, {}, wrapper_tag: "span") %></p>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="case-empty case-empty--inline">No notes yet. Start documenting the operating picture here.</div>
      <% end %>
    </section>
  </div>
</div>

<%# ── Controls ── horizontal toolbar at bottom ─────────────────── %>
<div id="controls-bar" role="toolbar" aria-label="Globe controls">
  <div class="cb-group">
    <button class="cb-btn" data-action="click->globe#zoomIn" data-tip="Zoom in" aria-label="Zoom in">
      <i class="fa-solid fa-plus" aria-hidden="true"></i>
    </button>
    <button class="cb-btn" data-action="click->globe#zoomOut" data-tip="Zoom out" aria-label="Zoom out">
      <i class="fa-solid fa-minus" aria-hidden="true"></i>
    </button>
  </div>
  <div class="cb-sep"></div>
  <div class="cb-group">
    <button class="cb-btn" data-action="click->globe#resetView" data-tip="Reset to default view" aria-label="Reset view">
      <i class="fa-solid fa-globe" aria-hidden="true"></i>
    </button>
    <button class="cb-btn" data-action="click->globe#viewTopDown" data-tip="Top-down view" aria-label="Top-down view">
      <i class="fa-solid fa-arrow-down" aria-hidden="true"></i>
    </button>
    <button class="cb-btn" data-action="click->globe#resetTilt" data-tip="Reset camera tilt" aria-label="Reset tilt">
      <i class="fa-solid fa-arrows-up-down" aria-hidden="true"></i>
    </button>
  </div>
  <div class="cb-sep"></div>
  <div class="cb-group">
    <button class="cb-btn cb-record" data-globe-target="recordBtn" data-action="click->globe#toggleRecording" data-tip="Record globe video" aria-label="Record video">
      <i class="fa-solid fa-circle" data-globe-target="recordIcon" aria-hidden="true"></i>
    </button>
    <button class="cb-btn" data-action="click->globe#takeScreenshot" data-tip="Take screenshot" aria-label="Take screenshot">
      <i class="fa-solid fa-camera" aria-hidden="true"></i>
    </button>
  </div>
  <div class="cb-sep"></div>
  <div class="cb-group">
    <button class="cb-btn" data-action="click->globe#shareView" data-tip="Copy shareable link" aria-label="Share link">
      <i class="fa-solid fa-share-nodes" aria-hidden="true"></i>
    </button>
  </div>
  <div class="cb-sep"></div>
  <div class="cb-group">
    <button class="cb-btn cb-timeline" data-action="click->globe#timelineOpen" data-tip="Time travel — scroll through history" aria-label="Open timeline">
      <i class="fa-solid fa-clock-rotate-left" aria-hidden="true"></i>
    </button>
  </div>
</div>

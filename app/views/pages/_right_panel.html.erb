<%# ── Unified Right Panel ── tabbed container ──────────────── %>
<div id="right-panel" data-globe-target="rightPanel" style="display:none;" role="tabpanel">
  <button class="detail-close" data-action="click->globe#closeRightPanel" aria-label="Close panel">&times;</button>
  <div class="rp-tabs" role="tablist" aria-label="Data panels">
    <button class="rp-tab active" data-action="click->globe#switchRightTab" data-rp-tab="entities" data-globe-target="rpTabEntities" role="tab" aria-selected="true">
      <i class="fa-solid fa-list" aria-hidden="true"></i> <span class="rp-tab-label">Entities</span>
    </button>
    <button class="rp-tab" data-action="click->globe#switchRightTab" data-rp-tab="news" data-globe-target="rpTabNews" style="display:none;" role="tab" aria-selected="false">
      <i class="fa-solid fa-newspaper" aria-hidden="true"></i> <span class="rp-tab-label">News</span>
    </button>
    <button class="rp-tab" data-action="click->globe#switchRightTab" data-rp-tab="threats" data-globe-target="rpTabThreats" style="display:none;" role="tab" aria-selected="false">
      <i class="fa-solid fa-shield-halved" aria-hidden="true"></i> <span class="rp-tab-label">Threats</span>
    </button>
    <button class="rp-tab" data-action="click->globe#switchRightTab" data-rp-tab="insights" data-globe-target="rpTabInsights" style="display:none;" role="tab" aria-selected="false">
      <i class="fa-solid fa-brain" aria-hidden="true"></i> <span class="rp-tab-label">Insights</span>
    </button>
    <button class="rp-tab" data-action="click->globe#switchRightTab" data-rp-tab="cameras" data-globe-target="rpTabCameras" style="display:none;" role="tab" aria-selected="false">
      <i class="fa-solid fa-video" aria-hidden="true"></i> <span class="rp-tab-label">Cameras</span>
    </button>
    <% if user_signed_in? %>
    <button class="rp-tab" data-action="click->globe#switchRightTab" data-rp-tab="alerts" data-globe-target="rpTabAlerts" style="display:none;" role="tab" aria-selected="false">
      <i class="fa-solid fa-bell" aria-hidden="true"></i> <span class="rp-tab-label">Alerts</span>
    </button>
    <% end %>
  </div>

  <%# ── Entities pane ── %>
  <div id="entity-list-panel" class="rp-pane rp-pane--active" data-rp-pane="entities" data-globe-target="entityListPanel" role="region" aria-label="Entity list">
    <div class="entity-list-header" data-globe-target="entityListHeader"></div>
    <div class="entity-list-tabs" role="tablist" aria-label="Entity types">
      <button class="entity-tab active" data-action="click->globe#switchEntityTab" data-tab="flights" role="tab" aria-selected="true">
        <i class="fa-solid fa-plane" aria-hidden="true"></i> <span data-globe-target="entityFlightCount">0</span>
      </button>
      <button class="entity-tab" data-action="click->globe#switchEntityTab" data-tab="ships" role="tab" aria-selected="false">
        <i class="fa-solid fa-ship" aria-hidden="true"></i> <span data-globe-target="entityShipCount">0</span>
      </button>
      <button class="entity-tab" data-action="click->globe#switchEntityTab" data-tab="satellites" role="tab" aria-selected="false">
        <i class="fa-solid fa-satellite" aria-hidden="true"></i> <span data-globe-target="entitySatCount">0</span>
      </button>
    </div>
    <div class="entity-airline-bar" data-globe-target="entityAirlineBar" style="display:none;">
      <div class="entity-airline-chips" data-globe-target="entityAirlineChips"></div>
    </div>
    <div class="entity-list-content" data-globe-target="entityListContent"></div>
  </div>

  <%# ── News pane ── %>
  <div class="rp-pane" data-rp-pane="news" data-globe-target="newsFeedPanel" role="region" aria-label="News feed">
    <div class="news-feed-header">
      <span class="news-feed-title">NEWS</span>
      <span class="news-feed-count" data-globe-target="newsFeedCount">0 articles</span>
    </div>
    <div class="nf-tabs" role="tablist">
      <button class="nf-tab nf-tab--active" data-action="click->globe#switchNewsTab" data-tab="articles" role="tab" aria-selected="true">ARTICLES</button>
      <button class="nf-tab" data-action="click->globe#switchNewsTab" data-tab="flows" role="tab" aria-selected="false">FLOWS</button>
    </div>
    <div class="nf-tab-pane nf-tab-articles" data-globe-target="newsArticlesPane">
      <div class="nf-filter-row">
        <select class="nf-cat-filter" data-globe-target="newsArticleCatFilter" data-action="change->globe#filterNewsArticles" aria-label="Filter by category">
          <option value="all">All</option>
          <option value="conflict">Conflict</option>
          <option value="unrest">Unrest</option>
          <option value="disaster">Disaster</option>
          <option value="health">Health</option>
          <option value="economy">Economy</option>
          <option value="diplomacy">Diplomacy</option>
          <option value="cyber">Cyber</option>
          <option value="other">Other</option>
        </select>
        <input type="text" class="nf-search" placeholder="Search headlines..." data-globe-target="newsArticleSearch" data-action="input->globe#filterNewsArticles" aria-label="Search news headlines">
      </div>
      <div class="nf-article-list" data-globe-target="newsArticleList"></div>
    </div>
    <div class="nf-tab-pane nf-tab-flows" data-globe-target="newsFlowsPane" style="display:none;">
      <div class="news-feed-content" data-globe-target="newsFeedContent"></div>
    </div>
  </div>

  <%# ── Threats pane ── %>
  <div class="rp-pane" data-rp-pane="threats" data-globe-target="threatsPanel" role="region" aria-label="Cyber threats">
    <div class="threats-header">
      <span class="threats-title"><i class="fa-solid fa-shield-halved" aria-hidden="true"></i> CYBER THREATS</span>
      <span class="threats-count" data-globe-target="threatsCount">0 targets</span>
    </div>
    <div class="threats-content" data-globe-target="threatsContent"></div>
  </div>

  <%# ── Insights pane ── %>
  <div class="rp-pane" data-rp-pane="insights" role="region" aria-label="Cross-layer insights">
    <div class="insight-feed-header">
      <span class="insight-feed-title"><i class="fa-solid fa-brain" aria-hidden="true"></i> CROSS-LAYER INSIGHTS</span>
      <span class="insight-feed-count" data-globe-target="insightFeedCount">0 insights</span>
    </div>
    <div class="insight-feed-list" data-globe-target="insightFeedContent"></div>
  </div>

  <%# ── Cameras pane ── %>
  <div class="rp-pane" data-rp-pane="cameras" data-globe-target="camFeedPanel" role="region" aria-label="Live cameras">
    <div class="cam-feed-header">
      <span class="cam-feed-title"><i class="fa-solid fa-video" aria-hidden="true"></i> CAMERAS</span>
      <span class="cam-feed-count" data-globe-target="camFeedCount">0 cameras</span>
    </div>
    <div class="cam-feed-filter">
      <input type="text" class="cam-feed-search" placeholder="Search cameras..." data-globe-target="camFeedSearch" data-action="input->globe#filterCamFeed" aria-label="Search cameras">
    </div>
    <div class="cam-feed-list" data-globe-target="camFeedList"></div>
  </div>

  <%# ── Alerts pane ── %>
  <% if user_signed_in? %>
  <div class="rp-pane" data-rp-pane="alerts" role="region" aria-label="Alert feed">
    <div class="alert-feed-header">
      <span class="alert-feed-title"><i class="fa-solid fa-bell" aria-hidden="true"></i> ALERTS</span>
      <button class="alert-mark-all" data-action="click->globe#markAllAlertsSeen">Mark all read</button>
    </div>
    <div class="alert-feed-list" data-globe-target="alertFeedContent"></div>
  </div>
  <% end %>
</div>

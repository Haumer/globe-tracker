<%# ── Unified Right Panel ── tabbed container ──────────────── %>
<div id="right-panel" data-globe-target="rightPanel" style="display:none;" role="tabpanel">
  <button class="detail-close" data-action="click->globe#closeRightPanel" aria-label="Close panel">&times;</button>
  <div class="rp-tabs" role="tablist" aria-label="Data panels">
    <button class="rp-tab" data-action="click->globe#switchRightTab" data-rp-tab="context" data-globe-target="rpTabContext" style="display:none;" role="tab" aria-selected="false">
      <i class="fa-solid fa-diagram-project" aria-hidden="true"></i> <span class="rp-tab-label">Context</span>
    </button>
    <button class="rp-tab" data-action="click->globe#switchRightTab" data-rp-tab="entities" data-globe-target="rpTabEntities" style="display:none;" role="tab" aria-selected="false">
      <i class="fa-solid fa-list" aria-hidden="true"></i> <span class="rp-tab-label">Entities</span>
    </button>
    <button class="rp-tab" data-action="click->globe#switchRightTab" data-rp-tab="news" data-globe-target="rpTabNews" style="display:none;" role="tab" aria-selected="false">
      <i class="fa-solid fa-newspaper" aria-hidden="true"></i> <span class="rp-tab-label">News</span>
    </button>
    <button class="rp-tab" data-action="click->globe#switchRightTab" data-rp-tab="threats" data-globe-target="rpTabThreats" style="display:none;" role="tab" aria-selected="false">
      <i class="fa-solid fa-shield-halved" aria-hidden="true"></i> <span class="rp-tab-label">Threats</span>
    </button>
    <button class="rp-tab" data-action="click->globe#switchRightTab" data-rp-tab="situations" data-globe-target="rpTabSituations" style="display:none;" role="tab" aria-selected="false">
      <i class="fa-solid fa-crosshairs" aria-hidden="true"></i> <span class="rp-tab-label">Theaters</span>
    </button>
    <button class="rp-tab" data-action="click->globe#switchRightTab" data-rp-tab="insights" data-globe-target="rpTabInsights" role="tab" aria-selected="false">
      <i class="fa-solid fa-brain" aria-hidden="true"></i> <span class="rp-tab-label">Insights</span>
    </button>
    <button class="rp-tab" data-action="click->globe#switchRightTab" data-rp-tab="cameras" data-globe-target="rpTabCameras" style="display:none;" role="tab" aria-selected="false">
      <i class="fa-solid fa-video" aria-hidden="true"></i> <span class="rp-tab-label">Cameras</span>
    </button>
    <% if user_signed_in? %>
    <button class="rp-tab" data-action="click->globe#switchRightTab" data-rp-tab="alerts" data-globe-target="rpTabAlerts" style="display:none;" role="tab" aria-selected="false">
      <i class="fa-solid fa-bell" aria-hidden="true"></i> <span class="rp-tab-label">Alerts</span>
    </button>
    <% end %>
  </div>

  <%# ── Context pane ── %>
  <div class="rp-pane" data-rp-pane="context" data-globe-target="contextPanel" role="region" aria-label="Selected context">
    <div class="insight-feed-header">
      <div class="insight-feed-title context-feed-title">
        <i class="fa-solid fa-diagram-project" aria-hidden="true"></i>
        <span class="context-feed-title-text">Operational Context</span>
      </div>
    </div>
    <div class="rp-pane-note rp-pane-note--context">Merged operational view for the current story, theater, or node.</div>
    <div class="insight-feed-list" data-globe-target="contextContent">
      <div class="context-empty">Click a map item to inspect the deeper context here.</div>
    </div>
  </div>

  <%# ── Entities pane ── %>
  <div id="entity-list-panel" class="rp-pane" data-rp-pane="entities" data-globe-target="entityListPanel" role="region" aria-label="Entity list">
    <div class="entity-list-header" data-globe-target="entityListHeader"></div>
    <div class="entity-list-tabs" role="tablist" aria-label="Entity types">
      <button class="entity-tab active" data-action="click->globe#switchEntityTab" data-tab="flights" role="tab" aria-selected="true">
        <i class="fa-solid fa-plane" aria-hidden="true"></i> <span data-globe-target="entityFlightCount">0</span>
      </button>
      <button class="entity-tab" data-action="click->globe#switchEntityTab" data-tab="ships" role="tab" aria-selected="false">
        <i class="fa-solid fa-ship" aria-hidden="true"></i> <span data-globe-target="entityShipCount">0</span>
      </button>
      <button class="entity-tab" data-action="click->globe#switchEntityTab" data-tab="satellites" role="tab" aria-selected="false">
        <i class="fa-solid fa-satellite" aria-hidden="true"></i> <span data-globe-target="entitySatCount">0</span>
      </button>
    </div>
    <div class="entity-airline-bar" data-globe-target="entityAirlineBar" style="display:none;">
      <div class="entity-airline-chips" data-globe-target="entityAirlineChips"></div>
    </div>
    <span class="rp-loading" data-globe-target="entitiesLoading" style="display:none;">Loading...</span>
    <p class="rp-empty" data-globe-target="entitiesEmpty" style="display:none;">Enable a tracking layer to see entities here.</p>
    <div class="entity-list-content" data-globe-target="entityListContent"></div>
  </div>

  <%# ── News pane ── %>
  <div class="rp-pane" data-rp-pane="news" data-globe-target="newsFeedPanel" role="region" aria-label="News feed">
    <div class="news-feed-header">
      <span class="news-feed-title">NEWS</span>
      <span class="news-feed-count" data-globe-target="newsFeedCount">0 articles</span>
    </div>
    <div class="nf-tabs" role="tablist">
      <button class="nf-tab nf-tab--active" data-action="click->globe#switchNewsTab" data-tab="articles" role="tab" aria-selected="true">ARTICLES</button>
      <button class="nf-tab" data-action="click->globe#switchNewsTab" data-tab="flows" role="tab" aria-selected="false">FLOWS</button>
    </div>
    <div class="nf-tab-pane nf-tab-articles" data-globe-target="newsArticlesPane">
      <div class="nf-filter-row">
        <input type="text" class="nf-search" placeholder="Search headlines..." data-globe-target="newsArticleSearch" data-action="input->globe#filterNewsArticles" aria-label="Search news headlines">
        <select class="nf-sort-select" data-globe-target="newsSortSelect" data-action="change->globe#filterNewsArticles" aria-label="Sort articles">
          <option value="newest">Newest</option>
          <option value="priority">Priority</option>
          <option value="intensity">Intensity</option>
        </select>
        <label class="nf-hide-read-label">
          <input type="checkbox" data-globe-target="newsHideReadToggle" data-action="change->globe#filterNewsArticles">
          <span>Hide read</span>
        </label>
        <label class="nf-hide-read-label">
          <input type="checkbox" checked data-globe-target="newsClusterToggle" data-action="change->globe#toggleNewsClustering">
          <span>Group</span>
        </label>
      </div>
      <div class="nf-cat-chips" data-globe-target="newsCatChips">
        <button class="nf-cat-chip" data-category="conflict" data-action="click->globe#toggleNewsCatChip" style="border-color:#f44336;color:#f44336;">Conflict</button>
        <button class="nf-cat-chip" data-category="unrest" data-action="click->globe#toggleNewsCatChip" style="border-color:#ff9800;color:#ff9800;">Unrest</button>
        <button class="nf-cat-chip" data-category="disaster" data-action="click->globe#toggleNewsCatChip" style="border-color:#ff5722;color:#ff5722;">Disaster</button>
        <button class="nf-cat-chip" data-category="health" data-action="click->globe#toggleNewsCatChip" style="border-color:#4caf50;color:#4caf50;">Health</button>
        <button class="nf-cat-chip" data-category="economy" data-action="click->globe#toggleNewsCatChip" style="border-color:#2196f3;color:#2196f3;">Economy</button>
        <button class="nf-cat-chip" data-category="diplomacy" data-action="click->globe#toggleNewsCatChip" style="border-color:#9c27b0;color:#9c27b0;">Diplomacy</button>
        <button class="nf-cat-chip" data-category="cyber" data-action="click->globe#toggleNewsCatChip" style="border-color:#00bcd4;color:#00bcd4;">Cyber</button>
        <button class="nf-cat-chip" data-category="other" data-action="click->globe#toggleNewsCatChip" style="border-color:#90a4ae;color:#90a4ae;">Other</button>
      </div>
      <div class="nf-trending-bar" data-globe-target="newsTrendingBar"></div>
      <span class="rp-loading" data-globe-target="newsLoading" style="display:none;">Loading...</span>
      <p class="rp-empty" data-globe-target="newsEmpty" style="display:none;">No news articles yet. Enable the News layer to fetch headlines.</p>
      <div class="nf-article-list" data-globe-target="newsArticleList"></div>
    </div>
    <div class="nf-tab-pane nf-tab-flows" data-globe-target="newsFlowsPane" style="display:none;">
      <div class="news-feed-content" data-globe-target="newsFeedContent"></div>
    </div>
  </div>

  <%# ── Threats pane ── %>
  <div class="rp-pane" data-rp-pane="threats" data-globe-target="threatsPanel" role="region" aria-label="Cyber threats">
    <div class="threats-header">
      <span class="threats-title"><i class="fa-solid fa-shield-halved" aria-hidden="true"></i> CYBER THREATS</span>
      <span class="threats-count" data-globe-target="threatsCount">0 targets</span>
    </div>
    <span class="rp-loading" data-globe-target="threatsLoading" style="display:none;">Loading...</span>
    <p class="rp-empty" data-globe-target="threatsEmpty" style="display:none;">No cyber threats detected in view.</p>
    <div class="threats-content" data-globe-target="threatsContent"></div>
  </div>

  <%# ── Situations pane ── %>
  <div class="rp-pane" data-rp-pane="situations" role="region" aria-label="Conflict theaters">
    <div class="sit-header">
      <span class="sit-title"><i class="fa-solid fa-crosshairs" aria-hidden="true"></i> CONFLICT THEATERS <span style="font:600 9px 'JetBrains Mono',monospace;color:rgba(255,152,0,0.7);letter-spacing:0.8px;">DERIVED</span></span>
      <span class="sit-count" data-globe-target="sitCount">0 theaters</span>
    </div>
    <div class="rp-pane-note rp-pane-note--situations">Derived from reporting and corroborating signals, not ground-truth incidents.</div>
    <span class="rp-loading" data-globe-target="sitLoading" style="display:none;">Loading...</span>
    <p class="rp-empty" data-globe-target="sitEmpty" style="display:none;">No active conflict theaters detected.</p>
    <div class="sit-list" data-globe-target="sitList"></div>
  </div>

  <%# ── Insights pane ── %>
  <div class="rp-pane" data-rp-pane="insights" role="region" aria-label="Cross-layer insights">
    <div class="insight-feed-header">
      <span class="insight-feed-title"><i class="fa-solid fa-brain" aria-hidden="true"></i> INSIGHTS</span>
      <span class="insight-feed-count" data-globe-target="insightFeedCount">0 insights</span>
    </div>
    <% if current_user&.admin? %>
    <button class="detail-track-btn" style="margin:8px 12px;background:rgba(171,71,188,0.15);border-color:rgba(171,71,188,0.3);color:#ce93d8;font:600 10px 'JetBrains Mono',monospace;letter-spacing:0.5px;" data-action="click->globe#loadBrief">
      <i class="fa-solid fa-file-lines" style="margin-right:4px;"></i>INTELLIGENCE BRIEF
    </button>
    <% end %>
    <div id="intelligence-brief" style="display:none;padding:8px 12px;"></div>
    <span class="rp-loading" data-globe-target="insightsLoading" style="display:none;">Loading...</span>
    <p class="rp-empty" data-globe-target="insightsEmpty" style="display:none;">No insights yet. Enable multiple layers for cross-layer analysis.</p>
    <div class="insight-feed-list" data-globe-target="insightFeedContent"></div>
  </div>

  <%# ── Cameras pane ── %>
  <div class="rp-pane" data-rp-pane="cameras" data-globe-target="camFeedPanel" role="region" aria-label="Live cameras">
    <div class="cam-feed-header">
      <span class="cam-feed-title"><i class="fa-solid fa-video" aria-hidden="true"></i> CAMERAS</span>
      <span class="cam-feed-count" data-globe-target="camFeedCount">0 cameras</span>
    </div>
    <div class="cam-feed-filter">
      <input type="text" class="cam-feed-search" placeholder="Search cameras..." data-globe-target="camFeedSearch" data-action="input->globe#filterCamFeed" aria-label="Search cameras">
    </div>
    <span class="rp-loading" data-globe-target="camerasLoading" style="display:none;">Loading...</span>
    <p class="rp-empty" data-globe-target="camerasEmpty" style="display:none;">No cameras in view. Enable the Cameras layer to see live feeds.</p>
    <div class="cam-feed-list" data-globe-target="camFeedList"></div>
  </div>

  <%# ── Alerts pane ── %>
  <% if user_signed_in? %>
  <div class="rp-pane" data-rp-pane="alerts" role="region" aria-label="Alert feed">
    <div class="alert-feed-header">
      <span class="alert-feed-title"><i class="fa-solid fa-bell" aria-hidden="true"></i> ALERTS</span>
      <button class="alert-mark-all" data-action="click->globe#markAllAlertsSeen">Mark all read</button>
    </div>
    <div class="alert-feed-list" data-globe-target="alertFeedContent"></div>
  </div>
  <% end %>
</div>

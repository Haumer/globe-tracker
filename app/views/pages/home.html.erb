<div id="globe-container"
     data-controller="globe"
     data-globe-cesium-token-value="<%= ENV['CESIUM_ION_TOKEN'] %>"
     data-globe-signed-in-value="<%= user_signed_in? %>"
     data-globe-saved-prefs-value="<%= (current_user&.preferences || {}).to_json %>">
  <div id="cesium-viewer"></div>

  <%# ── Sidebar toggle ── ─────────────────────────────────────── %>
  <button id="sidebar-toggle" data-action="click->globe#toggleSidebar" data-tip="Toggle panel" data-tip-pos="right" aria-label="Toggle sidebar">
    <i class="fa-solid fa-bars" aria-hidden="true"></i>
    <span class="sb-toggle-badge" id="sidebar-layer-badge" style="display:none;">0</span>
  </button>

  <%# ── Sidebar ── left side ────────────────────────────────────── %>
  <div id="sidebar" data-globe-target="sidebar" role="navigation" aria-label="Layer controls">
    <div class="sb-sheet-handle" data-action="click->globe#toggleSidebar"></div>

    <div class="sb-header">
      <span class="sb-header-title">LAYERS</span>
      <button class="sb-header-close" data-action="click->globe#toggleSidebar" aria-label="Close sidebar">&times;</button>
    </div>

    <%# Workspace selector (logged-in users only) %>
    <% if user_signed_in? %>
    <div class="ws-bar" data-globe-target="workspaceBar">
      <select class="ws-select" data-globe-target="workspaceSelect" data-action="change->globe#loadWorkspace" aria-label="Select workspace">
        <option value="">— Workspaces —</option>
      </select>
      <button class="ws-btn" data-action="click->globe#saveWorkspace" data-tip="Save current view" data-tip-pos="below" aria-label="Save workspace">
        <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
      </button>
      <button class="ws-btn" data-action="click->globe#deleteWorkspace" data-tip="Delete workspace" data-tip-pos="below" data-globe-target="workspaceDeleteBtn" style="display:none;" aria-label="Delete workspace">
        <i class="fa-solid fa-trash-can" aria-hidden="true"></i>
      </button>
    </div>
    <% end %>

    <%# Region Mode %>
    <div class="region-bar">
      <div class="region-launch-card">
        <div class="region-launch-copy">
          <div class="region-launch-kicker">Regional Profile</div>
          <div class="region-launch-title">DACH Local Mode</div>
          <div class="region-launch-desc">Switch from the global globe into a scoped DACH shell for checking regional data enrichment.</div>
        </div>
        <button class="region-local-btn" data-action="click->globe#openDachLocalProfile" type="button">Open</button>
      </div>
      <div id="region-indicator" style="display:none;"></div>
      <select class="region-select" id="region-select" data-action="change->globe#selectRegion" aria-label="Focus on a region">
        <option value="">Select Region</option>
      </select>
    </div>

    <%# Search %>
    <div class="sb-search">
      <i class="fa-solid fa-magnifying-glass sb-search-icon" aria-hidden="true"></i>
      <input type="text"
             class="sb-search-input"
             placeholder="Search..."
             data-globe-target="searchInput"
             data-action="input->globe#onSearchInput keydown->globe#onSearchKeydown"
             autocomplete="off"
             aria-label="Search entities">
      <button class="sb-search-clear" data-globe-target="searchClear" data-action="click->globe#clearSearch" style="display:none;" aria-label="Clear search">&times;</button>
    </div>
    <div class="sb-search-results" data-globe-target="searchResults" style="display:none;" role="listbox"></div>

    <%= render "pages/quick_bar" %>
    <%= render "pages/sidebar_sections" %>
  </div>

  <%= render "pages/right_panel" %>
  <%= render "pages/mobile_hud" %>
  <div id="mobile-sheet-scrim" data-action="click->globe#dismissMobileSurface" aria-hidden="true"></div>

  <div id="anchor-overlay" data-globe-target="anchorOverlay" style="display:none;" aria-hidden="true">
    <div class="anchor-pinned-layer" data-globe-target="anchorPins"></div>
    <svg id="anchor-leader" data-globe-target="anchorLeader" style="display:none;" aria-hidden="true">
      <path data-globe-target="anchorLeaderPath"></path>
      <circle data-globe-target="anchorLeaderSocket" style="display:none;"></circle>
    </svg>
    <div id="anchor-panel" data-globe-target="anchorPanel" style="display:none;" role="complementary" aria-label="Focused item">
      <div class="anchor-content" data-globe-target="anchorContent"></div>
    </div>
  </div>

  <%# ── Detail + Selection Stack ── bottom-right ──────────────── %>
  <div id="detail-stack">
    <div id="detail-panel" data-globe-target="detailPanel" style="display: none;" role="complementary" aria-label="Entity details">
      <button class="detail-close" data-action="click->globe#closeDetail" aria-label="Close details">&times;</button>
      <div class="detail-content" data-globe-target="detailContent"></div>
    </div>
    <div id="selection-tray" data-globe-target="selectionTray" style="display:none;" role="region" aria-label="Selected entities">
      <div class="sel-tray-header">
        <span class="sel-tray-title">Selected</span>
        <button class="sel-tray-clear" data-action="click->globe#clearAllSelections">Clear all</button>
      </div>
      <div class="sel-tray-items" data-globe-target="selectionTrayItems"></div>
    </div>
  </div>

  <%= render "pages/timeline" %>
  <%= render "pages/bottom_strip" %>
  <%= render "pages/onboarding" %>
</div>
<div id="gt-tooltip" role="tooltip"></div>
<div id="gt-toast" role="status" aria-live="polite"></div>

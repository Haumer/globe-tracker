<%
  sources = @sources || SourceCatalog.entries
  # Layout: 4-column grid. Title cell is 2x2 in the center.
  # Row 1-2: 2 sources | TITLE (2x2) | 2 sources
  #                     |             |
  # Then remaining sources fill 4-col rows below.
  top_left = sources[0..1]    # 2 cells stacked left of title
  top_right = sources[2..3]   # 2 cells stacked right of title
  rest = sources[4..]         # remaining 26 fill rows below
%>
<div class="bento-sources">
  <nav class="bento-nav">
    <%= link_to root_path, class: "bento-nav-back" do %>
      <i class="fa-solid fa-arrow-left"></i> Back to Globe
    <% end %>
  </nav>

  <% cell = ->(s) do %>
    <% if s[:link] %>
      <a href="<%= s[:link] %>" target="_blank" rel="noopener" class="bento-cell">
    <% else %>
      <div class="bento-cell">
    <% end %>
        <div class="bento-cell-icon"><i class="<%= s[:icon] %>"></i></div>
        <div class="bento-cell-name"><%= s[:title] %></div>
        <span class="bento-badge bento-badge--<%= s[:status_class] || 'default' %>"><%= s[:status] %></span>
    <% if s[:link] %>
      </a>
    <% else %>
      </div>
    <% end %>
  <% end %>

  <div class="bento-grid">
    <% top_left.each { |s| cell.call(s) } %>

    <div class="bento-cell bento-cell--title">
      <div class="bento-title-label">[01] DATA SOURCES</div>
      <h1 class="bento-title">Aggregating<br>the world's<br>open data</h1>
      <p class="bento-title-sub"><%= sources.size %> sources across aviation, maritime, space, earth science, security, news, and infrastructure.</p>
    </div>

    <% top_right.each { |s| cell.call(s) } %>
    <% rest.each { |s| cell.call(s) } %>

    <div class="bento-cell bento-cell--footer">
      <div class="bento-footer-text">Source freshness, rights, methodology, and confidence vary by layer.</div>
    </div>
  </div>
</div>

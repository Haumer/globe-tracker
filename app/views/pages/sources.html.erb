<%
  sources = [
    { icon: "fa-solid fa-plane",            title: "ADS-B Exchange",        status: "LIVE",     status_class: "live" },
    { icon: "fa-solid fa-tower-broadcast",  title: "OpenSky Network",       status: "API" },
    { icon: "fa-solid fa-ship",             title: "AIS Stream",            status: "LIVE",     status_class: "live" },
    { icon: "fa-solid fa-satellite",        title: "CelesTrak",             status: "API" },
    { icon: "fa-solid fa-house-crack",      title: "USGS Earthquakes",      status: "LIVE",     status_class: "live" },
    { icon: "fa-solid fa-fire",             title: "NASA FIRMS",            status: "API" },
    { icon: "fa-solid fa-newspaper",        title: "GDELT Project",         status: "LIVE",     status_class: "live" },
    { icon: "fa-solid fa-rss",              title: "Direct RSS Feeds",      status: "RSS" },
    { icon: "fa-solid fa-rss",              title: "Multi-source News",     status: "API" },
    { icon: "fa-solid fa-satellite-dish",   title: "GPS Interference",      status: "COMPUTED", status_class: "computed" },
    { icon: "fa-solid fa-crosshairs",       title: "UCDP Conflicts",        status: "API" },
    { icon: "fa-solid fa-cloud",            title: "Cloudflare Radar",      status: "LIVE",     status_class: "live" },
    { icon: "fa-solid fa-network-wired",    title: "TeleGeography",         status: "FREE",     status_class: "free" },
    { icon: "fa-solid fa-wifi",             title: "IODA Outages",          status: "FREE",     status_class: "free" },
    { icon: "fa-solid fa-bolt",             title: "NASA EONET",            status: "API" },
    { icon: "fa-solid fa-video",            title: "Windy Webcams",         status: "API" },
    { icon: "fa-brands fa-youtube",         title: "YouTube Live",          status: "LIVE",     status_class: "live" },
    { icon: "fa-solid fa-traffic-light",    title: "NYC Traffic Cams",      status: "LIVE",     status_class: "live" },
    { icon: "fa-solid fa-globe",            title: "Cesium Ion",            status: "ENGINE" },
    { icon: "fa-solid fa-building",         title: "Google 3D Tiles",       status: "ENGINE" },
    { icon: "fa-solid fa-map",              title: "Natural Earth",         status: "FREE",     status_class: "free" },
    { icon: "fa-solid fa-user-astronaut",   title: "UCS Satellites",        status: "OSS",      status_class: "oss" },
    { icon: "fa-solid fa-user-secret",      title: "Classified Sat Intel",  status: "COMPUTED", status_class: "computed" },
    { icon: "fa-solid fa-plane-lock",       title: "OpenAIP Airspace",      status: "API" },
    { icon: "fa-solid fa-plane-departure",  title: "OurAirports",           status: "OSS",      status_class: "oss" },
    { icon: "fa-solid fa-jet-fighter",      title: "Military Classifier",   status: "COMPUTED", status_class: "computed" },
    { icon: "fa-solid fa-oil-well",         title: "Global Energy Monitor", status: "FREE",     status_class: "free" },
    { icon: "fa-solid fa-bolt",             title: "Power Plant Database",  status: "OSS",      status_class: "oss" },
    { icon: "fa-solid fa-chart-line",       title: "Alpha Vantage",         status: "API" },
    { icon: "fa-solid fa-coins",            title: "European Central Bank", status: "FREE",     status_class: "free" },
  ]

  # Place title cell in the center of the grid.
  # 5 columns: 12 sources (fills rows 1-2 + 2 into row 3), then title at col 3, then rest.
  first_half = sources[0..11]
  second_half = sources[12..]
%>
<div class="bento-sources">
  <nav class="bento-nav">
    <%= link_to root_path, class: "bento-nav-back" do %>
      <i class="fa-solid fa-arrow-left"></i> Back to Globe
    <% end %>
  </nav>

  <div class="bento-grid">
    <% first_half.each do |s| %>
      <div class="bento-cell">
        <div class="bento-cell-icon"><i class="<%= s[:icon] %>"></i></div>
        <div class="bento-cell-name"><%= s[:title] %></div>
        <span class="bento-badge bento-badge--<%= s[:status_class] || 'default' %>"><%= s[:status] %></span>
      </div>
    <% end %>

    <div class="bento-cell bento-cell--title">
      <div class="bento-title-label">[01] DATA SOURCES</div>
      <h1 class="bento-title">Aggregating<br>the world's<br>open data</h1>
      <p class="bento-title-sub"><%= sources.size %> feeds across aviation, maritime, space, earth science, security, news, and infrastructure.</p>
    </div>

    <% second_half.each do |s| %>
      <div class="bento-cell">
        <div class="bento-cell-icon"><i class="<%= s[:icon] %>"></i></div>
        <div class="bento-cell-name"><%= s[:title] %></div>
        <span class="bento-badge bento-badge--<%= s[:status_class] || 'default' %>"><%= s[:status] %></span>
      </div>
    <% end %>

    <div class="bento-cell bento-cell--footer">
      <div class="bento-footer-text">All feeds are publicly accessible, community-driven, or computed in-house.</div>
    </div>
  </div>
</div>

<div class="src-page">
  <!-- Scanline overlay -->
  <div class="src-scanline"></div>

  <!-- Hero -->
  <header class="src-hero">
    <div class="src-hero-grid">
      <div class="src-hero-label">
        <span class="src-blink"></span>
        <span>LIVE DATA FEEDS</span>
      </div>
      <h1 class="src-hero-title">Open Source<br>Intelligence</h1>
      <p class="src-hero-sub">
        GlobeTracker aggregates <strong>25+ data sources</strong> across aviation, maritime,
        space, earth science, security, and world news &mdash; all rendered in real-time on a 3D globe.
        Every feed listed below is publicly accessible, community-driven, or computed in-house.
      </p>
    </div>

    <div class="src-stats">
      <div class="src-stat">
        <span class="src-stat-num">25+</span>
        <span class="src-stat-label">Data Feeds</span>
      </div>
      <div class="src-stat-sep"></div>
      <div class="src-stat">
        <span class="src-stat-num">8</span>
        <span class="src-stat-label">Categories</span>
      </div>
      <div class="src-stat-sep"></div>
      <div class="src-stat">
        <span class="src-stat-num">14</span>
        <span class="src-stat-label">Free / No Auth</span>
      </div>
      <div class="src-stat-sep"></div>
      <div class="src-stat">
        <span class="src-stat-num">5</span>
        <span class="src-stat-label">Real-time Streams</span>
      </div>
    </div>

    <div class="src-categories">
      <span class="src-cat" style="--cat: #4fc3f7;">Aviation</span>
      <span class="src-cat" style="--cat: #26c6da;">Maritime</span>
      <span class="src-cat" style="--cat: #ab47bc;">Space</span>
      <span class="src-cat" style="--cat: #ff7043;">Earth Science</span>
      <span class="src-cat" style="--cat: #66bb6a;">Imagery & Maps</span>
      <span class="src-cat" style="--cat: #ff9800;">News & Events</span>
      <span class="src-cat" style="--cat: #e040fb;">Infrastructure</span>
      <span class="src-cat" style="--cat: #f44336;">Security</span>
    </div>
  </header>

  <!-- Source Grid -->
  <section class="src-grid">

<% sources.each do |section_name, section| %>
    <!-- ═══════════════ <%= section[:comment] %> ═══════════════ -->

<% section[:items].each do |src| %>
    <%= render "pages/source_card",
          accent:       src[:accent] || section[:accent],
          icon:         src[:icon],
          title:        src[:title],
          url_label:    src[:url_label],
          status:       src[:status],
          status_class: src[:status_class],
          description:  src[:description],
          tags:         src[:tags],
          category:     src[:category],
          link:         src[:link] %>

<% end %>
<% end %>
  </section>

  <!-- Footer note -->
  <footer class="src-footer">
    <div class="src-footer-line"></div>
    <p>
      All data is sourced from publicly accessible APIs and open-source projects.
      GlobeTracker does not store or redistribute raw third-party data beyond what is
      necessary for real-time visualization. Please respect each provider's terms of service.
    </p>
    <div class="src-footer-back">
      <%= link_to root_path, class: "src-back-link" do %>
        <i class="fa-solid fa-arrow-left"></i>
        <span>Back to Globe</span>
      <% end %>
    </div>
  </footer>
</div>

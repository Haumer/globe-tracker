<nav class="globe-nav">
  <div class="globe-nav-brand">
    <%= link_to root_path do %>
      <span class="globe-nav-logo">GT</span>
      <span class="globe-nav-title">GlobeTracker</span>
    <% end %>
  </div>

  <%= render "pages/stats_bar" if controller_name == 'pages' && action_name == 'home' %>

  <div class="globe-nav-links">
    <%= link_to "Home", landing_path, class: "globe-nav-link" %>
    <%= link_to "Data Sources", sources_path, class: "globe-nav-link" %>
    <% if user_signed_in? %>
      <%= link_to "Cases", cases_path, class: "globe-nav-link" %>
      <%= link_to "Log out", destroy_user_session_path, data: { turbo_method: :delete }, class: "globe-nav-link" %>
    <% else %>
      <%= link_to "Login", new_user_session_path, class: "globe-nav-link" %>
    <% end %>
  </div>
</nav>
